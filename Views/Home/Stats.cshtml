@model IEnumerable<talentacquisition_jobplacement_mvc.Models.CV>
@{
    ViewData["Title"] = "Platform Statistics";
}

<h1 class="mb-4">TalentHub Statistics</h1>

<div class="row g-4 mb-5">
    <div class="col-md-3">
        <div class="card text-center h-100 border-primary shadow-sm">
            <div class="card-body">
                <h2 class="text-primary">@ViewBag.TotalCVs</h2>
                <p class="text-muted mb-0">Total CVs</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center h-100 border-success shadow-sm">
            <div class="card-body">
                <h2 class="text-success">@ViewBag.PublishedCVs</h2>
                <p class="text-muted mb-0">Published CVs</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center h-100 border-info shadow-sm">
            <div class="card-body">
                <h2 class="text-info">@ViewBag.TotalPositions</h2>
                <p class="text-muted mb-0">Job Positions</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center h-100 border-warning shadow-sm">
            <div class="card-body">
                <h2 class="text-warning">@ViewBag.TotalCandidates</h2>
                <p class="text-muted mb-0">Candidates</p>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-8">
        <h5>Recent Applications</h5>
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="table-light">
                        <tr>
                            <th>Candidate</th>
                            <th>Position</th>
                            <th>Applied On</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cv in Model)
                        {
                            <tr>
                                <td>@cv.User?.FullName</td>
                                <td>@cv.Position?.Title</td>
                                <td>@cv.CreatedAt.ToString("dd MMM yyyy HH:mm")</td>
                                <td>
                                    @if (cv.IsPublished)
                                    {
                                        <span class="badge bg-success">Published</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Draft</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted">No recent applications yet.</p>
        }
    </div>

    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-header">
                <h5>Quick Stats</h5>
            </div>
            <div class="card-body">
                <ul class="list-group list-group-flush">
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span>Recruiters</span>
                        <strong>@ViewBag.TotalRecruiters</strong>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span>Publish Rate</span>
                        <strong>@(ViewBag.TotalCVs > 0 ? Math.Round((double)ViewBag.PublishedCVs / ViewBag.TotalCVs * 100) : 0)%</strong>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

<a asp-action="Index" class="btn btn-secondary mt-4">← Back to Home</a>