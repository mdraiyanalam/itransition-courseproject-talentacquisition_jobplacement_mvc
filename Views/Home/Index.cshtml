@{
    ViewData["Title"] = "Talent Acquisition";
}

<div class="bg-primary text-white py-5 text-center">
    <div class="container">
        <h1 class="display-4 fw-bold">Talent Acquisition</h1>
        <p class="lead mb-4">Connecting talented candidates with the right opportunities</p>
        <div class="d-flex justify-content-center gap-3">
            <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-light btn-lg">Get Started</a>
            <a asp-controller="Positions" asp-action="Index" class="btn btn-outline-light btn-lg">Browse Positions</a>
        </div>
    </div>
</div>

<div class="container my-5">
    <div class="row text-center">
        <div class="col-md-4">
            <i class="bi bi-briefcase-fill display-1 text-primary"></i>
            <h4 class="mt-3">Smart Positions</h4>
            <p>Custom job templates with dynamic attributes</p>
        </div>
        <div class="col-md-4">
            <i class="bi bi-file-earmark-text display-1 text-primary"></i>
            <h4 class="mt-3">Auto CV Generation</h4>
            <p>Professional PDFs generated instantly</p>
        </div>
        <div class="col-md-4">
            <i class="bi bi-people-fill display-1 text-primary"></i>
            <h4 class="mt-3">Easy Collaboration</h4>
            <p>Comments, likes &amp; team review</p>
        </div>
    </div>
</div>