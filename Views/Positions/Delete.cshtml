@model talentacquisition_jobplacement_mvc.Models.Position

@{
    ViewData["Title"] = "Delete Position";
}

<h1>Delete Position</h1>

<div class="alert alert-danger">
    <h4>Are you sure you want to delete this position?</h4>
    <p><strong>@Model.Title</strong></p>
    <p>This action cannot be undone. All associated CVs will also be deleted.</p>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Yes, Delete Position</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>