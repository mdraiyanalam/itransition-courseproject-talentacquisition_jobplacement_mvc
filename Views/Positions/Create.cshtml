@model talentacquisition_jobplacement_mvc.Models.Position
@{
    ViewData["Title"] = "Create New Position";
    var allAttributes = ViewBag.Attributes as List<talentacquisition_jobplacement_mvc.Models.AttributeDefinition> ?? new();
}

<h1>Create New Position</h1>

<form asp-action="Create" method="post" id="positionForm">
    <div class="row">
        <!-- Main Information -->
        <div class="col-md-8">
            <div class="mb-3">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" required />
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="5"></textarea>
            </div>
            <div class="row">
                <div class="col-md-6">
                    <label asp-for="Company" class="form-label">Company</label>
                    <input asp-for="Company" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Level" class="form-label">Level</label>
                    <select asp-for="Level" class="form-select">
                        <option value="">Select Level</option>
                        <option value="Junior">Junior</option>
                        <option value="Mid">Mid</option>
                        <option value="Senior">Senior</option>
                        <option value="Lead">Lead</option>
                    </select>
                </div>
            </div>
            <div class="mb-3 mt-3">
                <label asp-for="MaxProjects" class="form-label">Maximum Projects to show in CV</label>
                <input asp-for="MaxProjects" type="number" class="form-control" min="1" max="10" value="5" />
            </div>
            <div class="mb-3">
                <label class="form-label">Preferred Project Tags (comma separated)</label>
                <input asp-for="ProjectTags" class="form-control" placeholder="React, .NET, Azure, SQL" />
            </div>
        </div>

        <!-- Attributes Selection -->
        <div class="col-md-4">
            <h5>Select Attributes</h5>
            @foreach (var attr in allAttributes)
            {
                <div class="form-check mb-2">
                    <input type="checkbox" name="selectedAttributes" value="@attr.Id" class="form-check-input" />
                    <label class="form-check-label">
                        @attr.Name <small class="text-muted">(@attr.Type)</small>
                    </label>
                </div>
            }
        </div>
    </div>

    <!-- Simple Role-Based Access Rules -->
    <div class="card mt-4">
        <div class="card-header bg-primary text-white">
            <strong>Who Can Apply?</strong>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-4">
                    <div class="form-check">
                        <input type="radio" name="AccessRuleType" value="All" id="all" checked class="form-check-input">
                        <label class="form-check-label" for="all">All Candidates</label>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-check">
                        <input type="radio" name="AccessRuleType" value="RecruiterOnly" id="recruiter" class="form-check-input">
                        <label class="form-check-label" for="recruiter">Recruiters Only</label>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-check">
                        <input type="radio" name="AccessRuleType" value="AdminOnly" id="admin" class="form-check-input">
                        <label class="form-check-label" for="admin">Administrators Only</label>
                    </div>
                </div>
            </div>
            <input type="hidden" name="AccessRulesJson" id="AccessRulesJson" />
        </div>
    </div>

    <div class="mt-4">
        <button type="submit" class="btn btn-primary btn-lg">Create Position</button>
        <a asp-action="Index" class="btn btn-secondary btn-lg">Cancel</a>
    </div>
</form>

@section Scripts {
    <script>
        document.getElementById('positionForm').addEventListener('submit', function() {
            const selectedRule = document.querySelector('input[name="AccessRuleType"]:checked').value;
            let rules = [];

            if (selectedRule === "RecruiterOnly") {
                rules = [{ Type: "Role", Value: "Recruiter" }];
            } else if (selectedRule === "AdminOnly") {
                rules = [{ Type: "Role", Value: "Administrator" }];
            }
            // "All" = empty rules = open to everyone

            document.getElementById('AccessRulesJson').value = JSON.stringify(rules);
        });
    </script>
}