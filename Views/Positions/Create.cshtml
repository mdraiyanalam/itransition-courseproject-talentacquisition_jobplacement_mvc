@model talentacquisition_jobplacement_mvc.Models.Position
@{
    ViewData["Title"] = "Create New Position";
    var allAttributes = ViewBag.Attributes as List<talentacquisition_jobplacement_mvc.Models.AttributeDefinition>;
}

<h1>Create New Position</h1>

<form asp-action="Create" method="post" id="positionForm">
    <div class="row">
        <!-- Main Information -->
        <div class="col-md-8">
            <div class="mb-3">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" required />
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="5"></textarea>
            </div>
            <div class="row">
                <div class="col-md-6">
                    <label asp-for="Company" class="form-label">Company</label>
                    <input asp-for="Company" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Level" class="form-label">Level</label>
                    <select asp-for="Level" class="form-select">
                        <option value="">Select Level</option>
                        <option value="Junior">Junior</option>
                        <option value="Mid">Mid</option>
                        <option value="Senior">Senior</option>
                        <option value="Lead">Lead</option>
                    </select>
                </div>
            </div>
            <div class="mb-3 mt-3">
                <label asp-for="MaxProjects" class="form-label">Maximum Projects to show in CV</label>
                <input asp-for="MaxProjects" type="number" class="form-control" min="1" max="10" />
            </div>
            <div class="mb-3">
                <label class="form-label">Preferred Project Tags (comma separated)</label>
                <input asp-for="ProjectTags" class="form-control" placeholder="React, .NET, Azure, SQL" />
            </div>
        </div>

        <!-- Attributes Selection -->
        <div class="col-md-4">
            <h5>Select Attributes</h5>
            @if (allAttributes != null)
            {
                foreach (var attr in allAttributes)
                {
                    <div class="form-check mb-2">
                        <input type="checkbox" name="selectedAttributes" value="@attr.Id" class="form-check-input" />
                        <label class="form-check-label">
                            @attr.Name <small class="text-muted">(@attr.Type)</small>
                        </label>
                    </div>
                }
            }
        </div>
    </div>

    <!-- Access Rules - Improved UI -->
    <div class="card mt-4">
        <div class="card-header bg-primary text-white">
            <strong>Access Rules <small>(Killer Feature - Who can apply?)</small></strong>
        </div>
        <div class="card-body">
            <div id="rulesContainer"></div>
            <button type="button" class="btn btn-success btn-sm mt-3" onclick="addRule()">
                <i class="bi bi-plus-circle"></i> Add Access Rule
            </button>
            <input type="hidden" name="AccessRulesJson" id="AccessRulesJson" />
        </div>
    </div>

    <div class="mt-4">
        <button type="submit" class="btn btn-primary btn-lg">Create Position</button>
        <a asp-action="Index" class="btn btn-secondary btn-lg">Cancel</a>
    </div>
</form>

@section Scripts {
    <script>
        let rules = @Html.Raw(Model.AccessRules ?? "[]");

        function addRule() {
            const container = document.getElementById('rulesContainer');
            const index = rules.length;

            const ruleHtml = `
                <div class="border p-3 mb-3 rounded bg-light position-relative" id="rule-${index}">
                    <button type="button" class="btn-close position-absolute top-0 end-0 m-2" onclick="removeRule(${index})"></button>
                    <div class="row g-2">
                        <div class="col-md-5">
                            <label class="form-label small">Attribute</label>
                            <select class="form-select" id="attr-${index}" onchange="updateRule(${index})">
                                <option value="">Select Attribute</option>
                                @foreach (var attr in allAttributes ?? new List<AttributeDefinition>())
                                {
                                        <option value="@attr.Id">@attr.Name (@attr.Type)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small">Operator</label>
                            <select class="form-select" id="op-${index}" onchange="updateRule(${index})">
                                <option value="=">= Equal</option>
                                <option value="!=">≠ Not Equal</option>
                                <option value=">">&gt; Greater Than</option>
                                <option value="<">&lt; Less Than</option>
                                <option value=">=">≥ Greater or Equal</option>
                                <option value="<=">≤ Less or Equal</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small">Value</label>
                            <input type="text" class="form-control" id="val-${index}"
                                   placeholder="Value" onchange="updateRule(${index})" />
                        </div>
                    </div>
                </div>`;

            container.innerHTML += ruleHtml;
            rules.push({ AttributeDefinitionId: 0, Operator: "=", Value: "", Order: index });
        }

        function updateRule(index) {
            rules[index] = {
                AttributeDefinitionId: parseInt(document.getElementById(`attr-${index}`).value) || 0,
                Operator: document.getElementById(`op-${index}`).value,
                Value: document.getElementById(`val-${index}`).value.trim(),
                Order: index
            };
        }

        function removeRule(index) {
            const element = document.getElementById(`rule-${index}`);
            if (element) element.remove();
            rules = rules.filter((_, i) => i !== index);
        }

        document.getElementById('positionForm').addEventListener('submit', function() {
            document.getElementById('AccessRulesJson').value = JSON.stringify(
                rules.filter(r => r.AttributeDefinitionId > 0)
            );
        });

        window.onload = function() {
            if (rules.length > 0) {
                rules.forEach((rule, index) => {
                    addRule();
                    setTimeout(() => {
                        const attrSelect = document.getElementById(`attr-${index}`);
                        const opSelect = document.getElementById(`op-${index}`);
                        const valInput = document.getElementById(`val-${index}`);
                        if (attrSelect) attrSelect.value = rule.AttributeDefinitionId || "";
                        if (opSelect) opSelect.value = rule.Operator || "=";
                        if (valInput) valInput.value = rule.Value || "";
                    }, 150);
                });
            }
        };
    </script>
}