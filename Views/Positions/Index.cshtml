@model IEnumerable<talentacquisition_jobplacement_mvc.Models.Position>
@{
    ViewData["Title"] = "Job Positions";
}

<h1 class="mb-4">Available Positions</h1>

<!-- Search & Create Bar -->
<div class="row mb-4">
    <div class="col-md-8">
        <form asp-action="Index" method="get" class="d-flex">
            <input type="text" name="searchString" class="form-control me-2"
                   placeholder="Search positions by title, company or tags..."
                   value="@ViewBag.SearchString" />
            <button type="submit" class="btn btn-primary">Search</button>
            @if (!string.IsNullOrEmpty(ViewBag.SearchString))
            {
                <a asp-action="Index" class="btn btn-outline-secondary ms-2">Clear</a>
            }
        </form>
    </div>

    @if (User.IsInRole("Recruiter") || User.IsInRole("Administrator"))
    {
        <div class="col-md-4 text-end">
            <a asp-action="Create" class="btn btn-success">+ New Position</a>
        </div>
    }
</div>

<!-- Profile Warning -->
@if (ViewBag.ProfileIncomplete != null && (bool)ViewBag.ProfileIncomplete)
{
    <div class="alert alert-warning">
        <strong>Profile Incomplete!</strong> @ViewBag.ProfileMessage
        <a asp-controller="Profiles" asp-action="Index" class="alert-link">Complete your profile →</a>
    </div>
}

@if (Model.Any())
{
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Title</th>
                <th>Company</th>
                <th>Level</th>
                <th>Project Tags</th>
                <th>Attributes</th>
                <th>Created</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><strong>@item.Title</strong></td>
                    <td>@item.Company</td>
                    <td><span class="badge bg-info">@item.Level</span></td>
                    <td>@item.ProjectTags</td>
                    <td>
                        <span class="badge bg-primary">@item.PositionAttributes.Count</span>
                    </td>
                    <td>@item.CreatedAt.ToString("dd MMM yyyy")</td>
                    <td>
                        @if (User.IsInRole("Recruiter") || User.IsInRole("Administrator"))
                        {
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary me-1">Edit</a>
                            <a asp-action="Duplicate" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary me-1">Duplicate</a>
                            <a asp-action="CVs" asp-route-id="@item.Id" class="btn btn-sm btn-info me-1">
                                View CVs (@(item.CVs?.Count ?? 0))
                            </a>
                        }
                        else if (User.IsInRole("Candidate"))
                        {
                            <a asp-controller="CVs" asp-action="Create" asp-route-positionId="@item.Id"
                               class="btn btn-sm btn-success">Apply Now</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-info">No positions found.</div>
}