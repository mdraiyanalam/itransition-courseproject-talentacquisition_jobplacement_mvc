@model IEnumerable<talentacquisition_jobplacement_mvc.Models.Position>
@{
    ViewData["Title"] = "Job Positions";
}

<h1 class="mb-4">Available Positions</h1>

<!-- Search & Create Bar -->
<div class="row mb-4">
    <div class="col-md-8">
        <form asp-action="Index" method="get" class="d-flex">
            <input type="text" name="searchString" class="form-control me-2"
                   placeholder="Search positions by title, company or tags..."
                   value="@ViewBag.SearchString" />
            <button type="submit" class="btn btn-primary">Search</button>
            @if (!string.IsNullOrEmpty(ViewBag.SearchString))
            {
                <a asp-action="Index" class="btn btn-outline-secondary ms-2">Clear</a>
            }
        </form>
    </div>

    @if (User.IsInRole("Recruiter") || User.IsInRole("Administrator"))
    {
        <div class="col-md-4 text-end">
            <a asp-action="Create" class="btn btn-success">+ New Position</a>
        </div>
    }
</div>

<!-- Profile Warning -->
@if (ViewBag.ProfileIncomplete != null && (bool)ViewBag.ProfileIncomplete)
{
    <div class="alert alert-warning">
        <strong>Profile Incomplete!</strong> @ViewBag.ProfileMessage
        <a asp-controller="Profiles" asp-action="Index" class="alert-link">Complete your profile →</a>
    </div>
}

@if (Model.Any())
{
    <table class="table table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Title</th>
                <th>Company</th>
                <th>Level</th>
                <th>Project Tags</th>
                <th>Attributes</th>
                <th>Created</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><strong>@item.Title</strong></td>
                    <td>@item.Company</td>
                    <td><span class="badge bg-info">@item.Level</span></td>
                    <td>@item.ProjectTags</td>
                    <td><span class="badge bg-primary">@item.PositionAttributes.Count</span></td>
                    <td>@item.CreatedAt.ToString("dd MMM yyyy")</td>
                    <td class="text-end">
                        <div class="dropdown">
                            <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button"
                                    data-bs-toggle="dropdown" aria-expanded="false">
                                Actions
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                @if (User.IsInRole("Recruiter") || User.IsInRole("Administrator"))
                                {
                                    <li>
                                        <a class="dropdown-item" asp-action="Edit" asp-route-id="@item.Id">
                                            <i class="bi bi-pencil"></i> Edit
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-action="Duplicate" asp-route-id="@item.Id">
                                            <i class="bi bi-copy"></i> Duplicate
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-action="Details" asp-route-id="@item.Id">
                                            <i class="bi bi-eye"></i> View Applications (@(item.CVs?.Count ?? 0))
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-action="Details" asp-route-id="@item.Id">
                                            <i class="bi bi-chat-dots"></i> Discussions (@(item.DiscussionPosts?.Count ?? 0))
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <a class="dropdown-item text-danger" asp-action="Delete" asp-route-id="@item.Id"
                                           onclick="return confirm('Delete this position and all applications?')">
                                            <i class="bi bi-trash"></i> Delete
                                        </a>
                                    </li>
                                }
                                else if (User.IsInRole("Candidate"))
                                {
                                    <li>
                                        <a class="dropdown-item text-success" asp-controller="CVs" asp-action="Create"
                                           asp-route-positionId="@item.Id">
                                            <i class="bi bi-arrow-right-circle"></i> Apply Now
                                        </a>
                                    </li>
                                }
                            </ul>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-info">No positions found.</div>
}