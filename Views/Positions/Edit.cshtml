@model talentacquisition_jobplacement_mvc.Models.Position

@{
    ViewData["Title"] = "Edit Position";
    var allAttributes = ViewBag.Attributes as List<talentacquisition_jobplacement_mvc.Models.AttributeDefinition>;
    var selectedIds = ViewBag.SelectedAttributeIds as List<int> ?? new List<int>();
}

<h1>Edit Position</h1>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />

    <div class="row">
        <!-- Main Information -->
        <div class="col-md-8">
            <div class="mb-3">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" required />
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="5"></textarea>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <label asp-for="Company" class="form-label">Company / Department</label>
                    <input asp-for="Company" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Level" class="form-label">Level</label>
                    <select asp-for="Level" class="form-select">
                        <option value="">Select Level</option>
                        <option value="Junior">Junior</option>
                        <option value="Mid">Mid</option>
                        <option value="Senior">Senior</option>
                        <option value="Lead">Lead</option>
                    </select>
                </div>
            </div>

            <div class="mb-3 mt-3">
                <label asp-for="MaxProjects" class="form-label">Maximum Projects to show in CV</label>
                <input asp-for="MaxProjects" type="number" class="form-control" min="1" max="10" />
            </div>

            <div class="mb-3">
                <label class="form-label">Preferred Project Tags (comma separated)</label>
                <input asp-for="ProjectTags" class="form-control" placeholder="React, .NET, Azure, SQL" />
            </div>
        </div>

        <!-- Attributes Selection -->
        <div class="col-md-4">
            <h5>Select Attributes</h5>
            @if (allAttributes != null)
            {
                foreach (var attr in allAttributes)
                {
                    bool isChecked = selectedIds.Contains(attr.Id);
                    <div class="form-check mb-2">
                        <input type="checkbox" name="selectedAttributes" value="@attr.Id"
                               class="form-check-input" @(isChecked ? "checked" : "") />
                        <label class="form-check-label">
                            @attr.Name <small class="text-muted">(@attr.Type)</small>
                        </label>
                    </div>
                }
            }
        </div>
    </div>

    <!-- Access Rules -->
    <div class="card mt-4">
        <div class="card-header">
            <strong>Access Rules</strong>
        </div>
        <div class="card-body">
            <div class="mb-3">
                <label class="form-label fw-bold">Who can apply to this position?</label>
                <div class="form-check">
                    <input type="checkbox" name="AllowedRoles" value="Candidate" class="form-check-input"
                           checked="@(Model.AllowedRoles?.Contains("Candidate") == true)" />
                    <label class="form-check-label">Candidates</label>
                </div>
                <div class="form-check">
                    <input type="checkbox" name="AllowedRoles" value="Recruiter" class="form-check-input"
                           checked="@(Model.AllowedRoles?.Contains("Recruiter") == true)" />
                    <label class="form-check-label">Recruiters (Internal)</label>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Advanced Rules (JSON)</label>
                <textarea asp-for="AccessRules" class="form-control" rows="4"
                          placeholder='{"MinExperience": 2, "RequiredEnglishLevel": "Intermediate"}'></textarea>
            </div>
        </div>
    </div>

    <div class="mt-4">
        <button type="submit" class="btn btn-primary btn-lg">Save Changes</button>
        <a asp-action="Index" class="btn btn-secondary btn-lg">Cancel</a>
    </div>
</form>