@model IEnumerable<talentacquisition_jobplacement_mvc.Models.AttributeDefinition>
@{
    ViewData["Title"] = "Attribute Library";
    var categories = ViewBag.Categories as List<string> ?? new List<string>();
}

<h1>Attribute Library</h1>

<div class="row mb-4">
    <div class="col-md-8">
        <form asp-action="Index" method="get" class="d-flex gap-2">
            <input type="text" name="searchString" class="form-control" placeholder="Search..." value="@ViewBag.SearchString" />
            <select name="categoryFilter" class="form-select w-auto">
                <option value="">All Categories</option>
                @foreach (var cat in categories)
                {
                    <option value="@cat" selected="@(ViewBag.CategoryFilter == cat)">@cat</option>
                }
            </select>
            <button type="submit" class="btn btn-primary">Filter</button>
            <a asp-action="Index" class="btn btn-secondary">Clear</a>
        </form>
    </div>
    <div class="col-md-4 text-end">
        <a asp-action="Create" class="btn btn-success">+ New Attribute</a>
    </div>
</div>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Category</th>
            <th>Name</th>
            <th>Type</th>
            <th>Required</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td><span class="badge bg-secondary">@item.Category</span></td>
                <td><strong>@item.Name</strong></td>
                <td>@item.Type</td>
                <td>@(item.IsRequired ? "✅" : "❌")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger"
                       onclick="return confirm('Delete this attribute?')">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>