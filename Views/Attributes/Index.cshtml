@model IEnumerable<talentacquisition_jobplacement_mvc.Models.AttributeDefinition>
@{
    ViewData["Title"] = "Attribute Library";
    var categories = ViewBag.Categories as List<string> ?? new List<string>();
}

<h1 class="mb-4">Attribute Library</h1>

<!-- Search & Filter Bar -->
<div class="row mb-4">
    <div class="col-md-8">
        <form asp-action="Index" method="get" class="d-flex gap-2">
            <input type="text" name="searchString" class="form-control"
                   placeholder="Search attributes..." value="@ViewBag.SearchString" />

            <select name="categoryFilter" class="form-select w-auto" style="min-width: 180px;">
                <option value="">All Categories</option>
                @foreach (var cat in categories)
                {
                    <option value="@cat" selected="@(ViewBag.CategoryFilter == cat)">@cat</option>
                }
            </select>

            <button type="submit" class="btn btn-primary">Filter</button>
            <a asp-action="Index" class="btn btn-secondary">Clear</a>
        </form>
    </div>

    <div class="col-md-4 text-end">
        <a asp-action="Create" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> New Attribute
        </a>
    </div>
</div>

<!-- Recently Used Attributes -->
@if (ViewBag.RecentAttributes != null && ((List<AttributeDefinition>)ViewBag.RecentAttributes).Any())
{
    <h5 class="mt-3 mb-2 text-muted">Recently Used Attributes</h5>
    <div class="row mb-4">
        @foreach (var attr in (List<AttributeDefinition>)ViewBag.RecentAttributes)
        {
            <div class="col-md-3 col-lg-2 mb-2">
                <span class="badge bg-info fs-6 py-2">@attr.Name</span>
            </div>
        }
    </div>
}

<!-- Main Table -->
@if (Model.Any())
{
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Category</th>
                <th>Name</th>
                <th>Type</th>
                <th>Required</th>
                <th>Description</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><span class="badge bg-secondary">@item.Category</span></td>
                    <td><strong>@item.Name</strong></td>
                    <td>@item.Type</td>
                    <td>
                        @if (item.IsRequired)
                        {
                            <span class="text-success">✅ Yes</span>
                        }
                        else
                        {
                            <span class="text-muted">No</span>
                        }
                    </td>
                    <td>@(item.Description ?? "-")</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary me-1">
                            <i class="bi bi-pencil"></i> Edit
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger"
                           onclick="return confirm('Delete this attribute? This may affect existing positions.')">
                            <i class="bi bi-trash"></i> Delete
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-info">
        No attributes found matching your criteria.
    </div>
}