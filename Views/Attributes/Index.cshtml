@model IEnumerable<talentacquisition_jobplacement_mvc.Models.AttributeDefinition>

@{
    ViewData["Title"] = "Attribute Library";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Attribute Library</h1>
    <a asp-action="Create" class="btn btn-success">+ New Attribute</a>
</div>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>Type</th>
            <th>Required</th>
            <th>Options</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td><strong>@item.Name</strong></td>
                <td><span class="badge bg-info">@item.Type</span></td>
                <td>@(item.IsRequired ? "✅ Yes" : "No")</td>
                <td>@item.Options</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>