@model IEnumerable<talentacquisition_jobplacement_mvc.Models.AttributeDefinition>
@{
    ViewData["Title"] = "Attribute Library";
    var categories = ViewBag.Categories as List<string> ?? new List<string>();
}

<h1 class="mb-4">Attribute Library</h1>

<!-- Filters -->
<div class="card mb-4">
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-3 align-items-center">
            <div class="col-md-5">
                <input type="text" name="searchString" class="form-control" placeholder="Search by name or description..." value="@ViewBag.SearchString" />
            </div>
            <div class="col-md-4">
                <select name="categoryFilter" class="form-select">
                    <option value="">All Categories</option>
                    @foreach (var cat in categories)
                    {
                        <option value="@cat" selected="@(ViewBag.CategoryFilter == cat)">@cat</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-primary w-100"><i class="bi bi-filter"></i> Filter</button>
            </div>
        </form>
        @if (!string.IsNullOrEmpty(ViewBag.SearchString) || !string.IsNullOrEmpty(ViewBag.CategoryFilter))
        {
            <div class="mt-3">
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Clear All Filters</a>
            </div>
        }
    </div>
</div>

<!-- Recently Used -->
@if (ViewBag.RecentAttributes != null && ((List<talentacquisition_jobplacement_mvc.Models.AttributeDefinition>)ViewBag.RecentAttributes).Any())
{
    <h5 class="mb-3 text-success"><i class="bi bi-clock-history"></i> Recently Used Attributes</h5>
    <div class="row mb-4 g-3">
        @foreach (var attr in (List<talentacquisition_jobplacement_mvc.Models.AttributeDefinition>)ViewBag.RecentAttributes)
        {
            <div class="col-md-4 col-lg-3">
                <div class="border p-3 rounded bg-light h-100">
                    <strong>@attr.Name</strong><br />
                    <small class="text-muted">@attr.Category • @attr.Type</small>
                </div>
            </div>
        }
    </div>
    <hr class="my-4" />
}

<!-- Table -->
@if (!Model.Any())
{
    <div class="alert alert-info">No attributes found matching your criteria.</div>
}
else
{
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Category</th>
                <th>Name</th>
                <th>Type</th>
                <th>Required</th>
                <th>Description</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><span class="badge bg-secondary">@item.Category</span></td>
                    <td><strong>@item.Name</strong></td>
                    <td>@item.Type</td>
                    <td>@(item.IsRequired ? "<span class='text-success fw-bold'>✅ Yes</span>" : "<span class='text-muted'>No</span>")</td>
                    <td>@(item.Description ?? "<span class='text-muted'>-</span>")</td>
                    <td class="text-end">
                        <div class="dropdown">
                            <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">Actions</button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" asp-action="Edit" asp-route-id="@item.Id">Edit</a></li>
                                <li>
                                    <a class="dropdown-item text-danger" asp-action="Delete" asp-route-id="@item.Id"
                                       onclick="return confirm('Delete this attribute? This may affect existing positions and CVs.')">Delete</a>
                                </li>
                            </ul>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<div class="mt-4">
    <a asp-action="Create" class="btn btn-success btn-lg"><i class="bi bi-plus-circle"></i> New Attribute</a>
</div>