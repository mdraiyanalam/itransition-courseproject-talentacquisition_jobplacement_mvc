@model talentacquisition_jobplacement_mvc.Models.AttributeDefinition
@{
    ViewData["Title"] = "Delete Attribute";
}

<h1>Delete Attribute</h1>

<div class="alert alert-danger">
    <h4>Are you sure you want to delete this attribute?</h4>
    <p><strong>@Model.Name</strong> (@Model.Category)</p>
    <p class="text-danger">This action cannot be undone.</p>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>