@model List<talentacquisition_jobplacement_mvc.Controllers.UserRoleViewModel>
@{
    ViewData["Title"] = "User Management";
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col">
            <h1><i class="bi bi-people"></i> User Management</h1>
            <p class="text-muted">Manage user accounts, roles, and permissions</p>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="table-responsive">
        <table class="table table-striped table-hover table-sm">
            <thead class="table-dark">
                <tr>
                    <th width="20%">Email</th>
                    <th width="20%">Full Name</th>
                    <th width="25%">Roles</th>
                    <th width="10%">Status</th>
                    <th width="25%" class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <code>@item.User.Email</code>
                        </td>
                        <td>
                            @item.User.FullName
                        </td>
                        <td>
                            @if (item.Roles.Any())
                            {
                                @foreach (var role in item.Roles)
                                {
                                    <span class="badge bg-info me-1">@role</span>
                                }
                            }
                            else
                            {
                                <span class="text-muted">No roles</span>
                            }
                        </td>
                        <td>
                            @if (item.User.IsBlocked)
                            {
                                <span class="badge bg-danger">
                                    <i class="bi bi-lock-fill"></i> Blocked
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-success">
                                    <i class="bi bi-check-circle"></i> Active
                                </span>
                            }
                        </td>
                        <td class="text-end">
                            <div class="dropdown">
                                <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button"
                                        data-bs-toggle="dropdown" aria-expanded="false">
                                    Actions
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li>
                                        <a class="dropdown-item" href="@Url.Action("ViewProfile", "Admin", new { id = item.User.Id })">
                                            <i class="bi bi-person-circle"></i> View Profile
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" href="@Url.Action("EditRoles", "Admin", new { id = item.User.Id })">
                                            <i class="bi bi-lock"></i> Edit Roles
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    @if (item.User.IsBlocked)
                                    {
                                        <li>
                                            <form method="post" action="@Url.Action("UnblockUser", "Admin")" style="display: inline;" class="w-100">
                                                <input type="hidden" name="id" value="@item.User.Id" />
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="dropdown-item text-warning"
                                                        onclick="return confirm('Unblock this user?')">
                                                    <i class="bi bi-unlock-fill"></i> Unblock User
                                                </button>
                                            </form>
                                        </li>
                                    }
                                    else
                                    {
                                        <li>
                                            <form method="post" action="@Url.Action("BlockUser", "Admin")" style="display: inline;" class="w-100">
                                                <input type="hidden" name="id" value="@item.User.Id" />
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="dropdown-item text-danger"
                                                        onclick="return confirm('Block this user?')">
                                                    <i class="bi bi-lock-fill"></i> Block User
                                                </button>
                                            </form>
                                        </li>
                                    }
                                    <li>
                                        <button type="button" class="dropdown-item text-danger"
                                                data-bs-toggle="modal" data-bs-target="#deleteUserModal"
                                                data-user-id="@item.User.Id" data-user-email="@item.User.Email" data-user-name="@item.User.FullName">
                                            <i class="bi bi-trash"></i> Delete User
                                        </button>
                                    </li>
                                </ul>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center mt-4">
            <i class="bi bi-info-circle"></i> No users found.
        </div>
    }
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteUserModal" tabindex="-1" aria-labelledby="deleteUserModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="deleteUserModalLabel">
                    <i class="bi bi-exclamation-triangle"></i> Delete User
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-3">⚠️ <strong>This action is permanent and cannot be undone.</strong></p>
                <p>Are you sure you want to delete the following user?</p>
                <div class="card bg-light">
                    <div class="card-body">
                        <p class="mb-1"><strong id="modalUserEmail"></strong></p>
                        <p class="mb-0 text-muted" id="modalUserFullName"></p>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <form id="deleteUserForm" method="post" asp-controller="Admin" asp-action="DeleteUserConfirmed">
                    <input type="hidden" name="id" id="modalUserId" />
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash"></i> Delete User
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var deleteModal = document.getElementById('deleteUserModal');
            if (!deleteModal) return;
            deleteModal.addEventListener('show.bs.modal', function (event) {
                var button = event.relatedTarget;
                var userId = button.getAttribute('data-user-id');
                var userEmail = button.getAttribute('data-user-email');
                var userName = button.getAttribute('data-user-name');

                document.getElementById('modalUserId').value = userId;
                document.getElementById('modalUserEmail').textContent = userEmail;
                document.getElementById('modalUserFullName').textContent = userName;
            });
        });
    </script>
}