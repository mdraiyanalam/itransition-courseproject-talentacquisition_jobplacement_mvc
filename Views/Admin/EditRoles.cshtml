@model talentacquisition_jobplacement_mvc.Controllers.UserRoleEditViewModel

@{
    ViewData["Title"] = "Edit User Roles";
}

<h1>Edit Roles for @Model.FullName</h1>
<p><strong>Email:</strong> @Model.Email</p>

<form asp-action="EditRoles" method="post">
    <input type="hidden" asp-for="UserId" />

    <div class="mb-3">
        <h5>Available Roles</h5>
        @foreach (var role in Model.AllRoles)
        {
            bool isChecked = Model.CurrentRoles.Contains(role);
            <div class="form-check">
                <input type="checkbox" name="SelectedRoles" value="@role" class="form-check-input" @(isChecked ? "checked" : "") />
                <label class="form-check-label">@role</label>
            </div>
        }
    </div>

    <button type="submit" class="btn btn-primary">Save Roles</button>
    <a asp-action="Users" class="btn btn-secondary">Cancel</a>
</form>