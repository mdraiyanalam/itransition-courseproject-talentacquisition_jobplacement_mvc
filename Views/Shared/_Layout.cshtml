@using Microsoft.Extensions.Localization
@using talentacquisition_jobplacement_mvc.Resources
@using System.Globalization
@inject IStringLocalizer<SharedResources> SharedLocalizer

<!DOCTYPE html>
<html lang="@CultureInfo.CurrentUICulture.Name" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TalentHub</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        /* Toggle Switch for Theme */
        .switch {
            position: relative;
            display: inline-block;
            width: 50px;
            height: 26px;
        }

        .switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

        .slider {
            position: absolute;
            cursor: pointer;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: #ccc;
            transition: .4s;
            border-radius: 34px;
        }

        .slider:before {
            position: absolute;
            content: "";
            height: 20px;
            width: 20px;
            left: 3px;
            bottom: 3px;
            background-color: white;
            transition: .4s;
            border-radius: 50%;
        }

        input:checked + .slider {
            background-color: #2196F3;
        }

        input:checked + .slider:before {
            transform: translateX(24px);
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary fixed-top shadow">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <i class="bi bi-briefcase-fill"></i> Talent Acquisition
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Positions" asp-action="Index">
                            @SharedLocalizer["Positions"]
                        </a>
                    </li>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Profiles" asp-action="Index">
                                @SharedLocalizer["MyProfile"]
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="CVs" asp-action="MyApplications">
                                @SharedLocalizer["MyApplications"]
                            </a>
                        </li>
                    }
                    @if (User.IsInRole("Recruiter") || User.IsInRole("Administrator"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Attributes" asp-action="Index">
                                @SharedLocalizer["Attributes"]
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="CVs" asp-action="Index">
                                @SharedLocalizer["AllCVs"]
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Stats">
                                @SharedLocalizer["Statistics"]
                            </a>
                        </li>
                    }
                    @if (User.IsInRole("Administrator"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Admin" asp-action="Users">
                                @SharedLocalizer["Users"]
                            </a>
                        </li>
                    }
                </ul>

                <ul class="navbar-nav ms-auto">
                    <!-- Theme Toggle Switch -->
                    <li class="nav-item d-flex align-items-center me-3">
                        <label class="switch" title="Toggle Dark/Light Theme">
                            <input type="checkbox" id="themeToggle" onchange="toggleTheme()">
                            <span class="slider"></span>
                        </label>
                    </li>

                    <!-- Language Selector -->
                    <li class="nav-item">
                        @{
                            var currentCulture = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
                        }
                        <select class="form-select form-select-sm" style="width:140px"
                                onchange="window.location.href = '/SetCulture?culture=' + this.value + '&returnUrl=' + encodeURIComponent(window.location.pathname + window.location.search)">
                            @if (currentCulture == "uz")
                            {
                                <option value="uz" selected>🇺🇿 O'zbek</option>
                                <option value="en">🇬🇧 English</option>
                            }
                            else
                            {
                                <option value="en" selected>🇬🇧 English</option>
                                <option value="uz">🇺🇿 O'zbek</option>
                            }
                        </select>
                    </li>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle"></i> @User.Identity.Name
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" asp-area="Identity" asp-page="/Account/Manage/Index">Account Settings</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form asp-area="Identity" asp-page="/Account/Logout" method="post">
                                        <button type="submit" class="dropdown-item text-danger">@SharedLocalizer["Logout"]</button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item"><a class="nav-link" asp-area="Identity" asp-page="/Account/Login">@SharedLocalizer["Login"]</a></li>
                        <li class="nav-item"><a class="nav-link" asp-area="Identity" asp-page="/Account/Register">@SharedLocalizer["Register"]</a></li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @RenderBody()
    </div>

    <footer class="border-top py-4 mt-5 text-center text-muted">
        &copy; 2026 Talent Acquisition
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <script>
        // Theme Toggle
        function toggleTheme() {
            const html = document.documentElement;
            const isDark = html.getAttribute('data-bs-theme') === 'dark';
            html.setAttribute('data-bs-theme', isDark ? 'light' : 'dark');
            localStorage.setItem('theme', isDark ? 'light' : 'dark');
        }

        // Load saved theme
        if (localStorage.getItem('theme') === 'dark') {
            document.documentElement.setAttribute('data-bs-theme', 'dark');
            document.getElementById('themeToggle').checked = true;
        }
    </script>

    @{ /* debug only */ }
    <div style="position:fixed;right:0;top:0;background:#fff;padding:6px;z-index:9999;">
      UI: @System.Globalization.CultureInfo.CurrentUICulture.Name<br/>
      Culture: @System.Globalization.CultureInfo.CurrentCulture.Name<br/>
      Positions => @SharedLocalizer["Positions"]
    </div>
</body>
</html>