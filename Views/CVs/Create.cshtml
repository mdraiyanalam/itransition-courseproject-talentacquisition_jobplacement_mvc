@model talentacquisition_jobplacement_mvc.Models.CV

@{
    ViewData["Title"] = "Create CV";
    var position = Model.Position;
}

<h1>Apply to: @position?.Title</h1>
<p class="text-muted">@position?.Description</p>

<form asp-action="Create" method="post">
    <input type="hidden" asp-for="PositionId" />

    <h4 class="mt-4">Fill Required Information</h4>

    @if (position?.PositionAttributes != null && position.PositionAttributes.Any())
    {
        <div class="row">
            @foreach (var pa in position.PositionAttributes.OrderBy(x => x.Order))
            {
                var attr = pa.AttributeDefinition;
                <div class="col-md-6 mb-3">
                    <label class="form-label">
                        @attr.Name
                        @if (attr.IsRequired)
                        {
                            <span class="text-danger">*</span>
                        }
                    </label>

                    @switch (attr.Type)
                    {
                        case "Text":
                            <input type="text" name="attributeValues[@attr.Id]" class="form-control" required="@attr.IsRequired" />
                            break;

                        case "Number":
                            <input type="number" name="attributeValues[@attr.Id]" class="form-control" required="@attr.IsRequired" />
                            break;

                        case "Date":
                            <input type="date" name="attributeValues[@attr.Id]" class="form-control" required="@attr.IsRequired" />
                            break;

                        case "Boolean":
                            <select name="attributeValues[@attr.Id]" class="form-select">
                                <option value="Yes">Yes</option>
                                <option value="No">No</option>
                            </select>
                            break;

                        case "Dropdown":
                            <select name="attributeValues[@attr.Id]" class="form-select" required="@attr.IsRequired">
                                <option value="">-- Select --</option>
                                @if (!string.IsNullOrEmpty(attr.Options))
                                {
                                    foreach (var option in attr.Options.Split(',', StringSplitOptions.TrimEntries))
                                    {
                                        <option value="@option">@option</option>
                                    }
                                }
                            </select>
                            break;

                        default:
                            <input type="text" name="attributeValues[@attr.Id]" class="form-control" />
                            break;
                    }
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info">This position has no specific attributes defined yet.</div>
    }

    <div class="mt-4">
        <button type="submit" class="btn btn-success btn-lg">Submit CV</button>
        <a asp-controller="Positions" asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>