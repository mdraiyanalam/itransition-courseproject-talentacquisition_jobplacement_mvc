@model talentacquisition_jobplacement_mvc.Models.CV

@{
    ViewData["Title"] = $"Apply to {Model.Position?.Title}";
    var attributeValues = ViewBag.AttributeValues as Dictionary<int, string> ?? new Dictionary<int, string>();
}

<h1 class="mb-1">Apply to <strong>@Model.Position?.Title</strong></h1>
<p class="text-muted lead">@Model.Position?.Description</p>

<hr />

<form asp-action="Create" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="PositionId" />

    <div class="row">
        <!-- Main Form -->
        <div class="col-lg-8">
            <h4 class="mb-4">Required Information</h4>

            @if (Model.Position?.PositionAttributes != null && Model.Position.PositionAttributes.Any())
            {
                foreach (var pa in Model.Position.PositionAttributes.OrderBy(x => x.Order))
                {
                    var attr = pa.AttributeDefinition;
                    var currentValue = attributeValues.GetValueOrDefault(attr.Id, "");

                    <div class="card mb-4 shadow-sm">
                        <div class="card-body">
                            <label class="form-label fw-bold">
                                @attr.Name
                                @if (attr.IsRequired)
                                {
                                    <span class="text-danger">*</span>
                                }
                            </label>
                            @if (!string.IsNullOrEmpty(attr.Description))
                            {
                                <small class="text-muted d-block mb-2">@attr.Description</small>
                            }

                            @switch (attr.Type.ToLower())
                            {
                                case "dropdown":
                                    <select name="attributeValues[@attr.Id]"
                                            class="form-select"
                                            @(attr.IsRequired ? "required" : "")>
                                        <option value="">-- Select an option --</option>
                                        @if (!string.IsNullOrEmpty(attr.Options))
                                        {
                                            foreach (var option in attr.Options.Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries))
                                            {
                                                <option value="@option" selected="@(currentValue == option)">@option</option>
                                            }
                                        }
                                    </select>
                                    break;

                                case "number":
                                    <input type="number"
                                           name="attributeValues[@attr.Id]"
                                           class="form-control"
                                           value="@currentValue"
                                           step="0.01"
                                           @(attr.IsRequired ? "required" : "") />
                                    break;

                                case "boolean":
                                    <div class="form-check form-switch">
                                        <input type="hidden" name="attributeValues[@attr.Id]" value="false" />
                                        <input type="checkbox"
                                               name="attributeValues[@attr.Id]"
                                               value="true"
                                               class="form-check-input"
                                               @(currentValue == "true" || currentValue == "Yes" ? "checked" : "") />
                                        <label class="form-check-label">Yes / Available</label>
                                    </div>
                                    break;

                                case "date":
                                    <input type="date"
                                           name="attributeValues[@attr.Id]"
                                           class="form-control"
                                           value="@currentValue"
                                           @(attr.IsRequired ? "required" : "") />
                                    break;

                                default: // Text
                                         <textarea name="attributeValues[@attr.Id]"
                              class="form-control"
                              rows="4"
                              @(attr.IsRequired ? "required" : "")>@currentValue</textarea>
                                    break;
                            }
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="alert alert-info">
                    This position doesn't have any specific attributes yet. You can still apply.
                </div>
            }
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            <div class="sticky-top" style="top: 25px;">
                <div class="card shadow">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">Application Summary</h5>
                    </div>
                    <div class="card-body">
                        <p><strong>Position:</strong><br /> @Model.Position?.Title</p>
                        <p>
                            <strong>Attributes to fill:</strong><br />
                            <span class="badge bg-secondary">@Model.Position?.PositionAttributes.Count</span>
                        </p>

                        <hr />

                        <button type="submit" class="btn btn-success btn-lg w-100 mb-3">
                            <i class="bi bi-send-check"></i> Submit Application
                        </button>

                        <a asp-controller="Positions" asp-action="Index"
                           class="btn btn-outline-secondary w-100">
                            ← Back to Positions
                        </a>
                    </div>
                </div>

                <div class="mt-3 text-muted small text-center">
                    Your profile information will be automatically included in the CV.
                </div>
            </div>
        </div>
    </div>
</form>