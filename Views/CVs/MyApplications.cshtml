@model IEnumerable<talentacquisition_jobplacement_mvc.Models.CV>
@{
    ViewData["Title"] = "My Applications";
}

<h1>My Applications</h1>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @Html.Raw(TempData["Success"])
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (Model.Any())
{
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Position</th>
                <th>Applied On</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var cv in Model.OrderByDescending(c => c.CreatedAt))
            {
                <tr>
                    <td><strong>@cv.Position?.Title</strong></td>
                    <td>@cv.CreatedAt.ToString("dd MMM yyyy HH:mm")</td>
                    <td>
                        @if (cv.IsPublished)
                        {
                            <span class="badge bg-success">Published</span>
                        }
                        else
                        {
                            <span class="badge bg-warning">Draft</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@cv.Id" class="btn btn-sm btn-primary">View</a>
                        <a asp-action="Edit" asp-route-id="@cv.Id" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Download" asp-route-id="@cv.Id" class="btn btn-sm btn-success">Download PDF</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-info">
        You haven't applied to any positions yet.<br />
        <a asp-controller="Positions" asp-action="Index" class="alert-link">Browse Available Positions →</a>
    </div>
}