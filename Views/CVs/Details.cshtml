@model talentacquisition_jobplacement_mvc.Models.CV

@{
    ViewData["Title"] = "CV Details";
    var attrValues = ViewBag.AttributeValues as Dictionary<int, string> ?? new Dictionary<int, string>();
}

<h1>CV Details</h1>

<div class="card mb-4">
    <div class="card-body">
        <div class="row">
            <div class="col-md-8">
                <h3>@Model.Position?.Title</h3>
                <p><strong>Candidate:</strong> @Model.User?.FullName</p>
                <p><strong>Applied:</strong> @Model.CreatedAt.ToString("dd MMMM yyyy HH:mm")</p>
            </div>
            <div class="col-md-4 text-end">
                <a asp-action="Download" asp-route-id="@Model.Id" class="btn btn-success btn-lg">
                    <i class="bi bi-download"></i> Download PDF
                </a>
            </div>
        </div>
    </div>
</div>

<h4>Filled Information</h4>
<table class="table table-bordered table-hover">
    <thead class="table-dark">
        <tr>
            <th>Attribute</th>
            <th>Value</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var pa in Model.Position?.PositionAttributes.OrderBy(x => x.Order) ?? Enumerable.Empty<PositionAttribute>())
        {
            var attr = pa.AttributeDefinition;
            var value = attrValues.GetValueOrDefault(attr.Id, "Not Provided");
            <tr>
                <td><strong>@attr.Name</strong></td>
                <td>@value</td>
            </tr>
        }
    </tbody>
</table>

<div class="mt-4">
    @if (User.IsInRole("Candidate"))
    {
        <a asp-action="MyApplications" class="btn btn-secondary">← Back to My Applications</a>
    }
    else
    {
        <a asp-action="Index" class="btn btn-secondary">← Back to All CVs</a>
    }
</div>