@model talentacquisition_jobplacement_mvc.Models.CV
@using talentacquisition_jobplacement_mvc.Helpers
@using System.Security.Claims
@{
    ViewData["Title"] = $"CV - {Model.Position?.Title}";
    var attrValues = ViewBag.AttributeValues as Dictionary<int, string> ?? new Dictionary<int, string>();
    var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    bool isOwner = userId == Model.UserId;
    bool canEdit = isOwner || User.IsInRole("Administrator");
}

<h1>CV for <strong>@Model.Position?.Title</strong></h1>

<div class="row">
    <div class="col-md-8">
        <div class="card mb-4">
            <div class="card-body">
                <h3>@Model.User?.FullName</h3>
                <p><strong>Email:</strong> @Model.User?.Email</p>
                <p><strong>Applied:</strong> @Model.CreatedAt.ToString("dd MMMM yyyy HH:mm")</p>
            </div>
        </div>

        <!-- Like -->
        <form asp-action="ToggleLike" method="post" class="d-inline">
            <input type="hidden" name="cvId" value="@Model.Id" />
            <button type="submit" class="btn @(Model.Likes.Any(l => l.UserId == userId) ? "btn-danger" : "btn-outline-danger") mb-3">
                ❤️ @Model.Likes.Count
            </button>
        </form>

        <!-- Publish Controls -->
        @if (canEdit)
        {
            <div class="mb-4">
                @if (Model.IsPublished)
                {
                    <form asp-action="Unpublish" method="post" style="display:inline;">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-warning">Unpublish</button>
                    </form>
                }
                else
                {
                    <form asp-action="Publish" method="post" style="display:inline;">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-success">Publish CV</button>
                    </form>
                }
            </div>
        }

        <!-- Attributes -->
        <h5>Attribute Answers</h5>
        <table class="table table-striped">
            <thead class="table-light">
                <tr>
                    <th>Attribute</th>
                    <th>Value</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var pa in Model.Position?.PositionAttributes.OrderBy(x => x.Order) ?? Enumerable.Empty<PositionAttribute>())
                {
                    var attr = pa.AttributeDefinition;
                    var value = attrValues.GetValueOrDefault(attr.Id, "");
                    bool isEmpty = string.IsNullOrWhiteSpace(value);

                    <tr>
                        <td><strong>@attr.Name</strong> <small>(@attr.Type)</small></td>
                        <td>
                            @if (isEmpty)
                            {
                                <span class="text-danger fw-bold">NOT PROVIDED</span>
                            }
                            else
                            {
                                @value
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <!-- Projects -->
        @if (Model.CandidateProfile?.Projects.Any() == true)
        {
            <h5>Selected Projects</h5>
            @foreach (var p in Model.CandidateProfile.Projects.Take(Model.Position?.MaxProjects ?? 5))
            {
                <div class="border p-3 mb-3 rounded">
                    <h6>@p.Name</h6>
                    <small class="text-muted">@p.StartDate.ToShortDateString() — @(p.EndDate?.ToShortDateString() ?? "Present")</small>
                    <p>@Html.Raw(MarkdownHelper.ToHtml(p.Description))</p>
                    @if (!string.IsNullOrEmpty(p.TechnologyTags))
                    {
                        <p><strong>Technologies:</strong> @p.TechnologyTags</p>
                    }
                </div>
            }
        }
    </div>

    <!-- Sidebar -->
    <div class="col-md-4">
        <a asp-action="Download" asp-route-id="@Model.Id" class="btn btn-primary w-100 mb-3">
            <i class="bi bi-download"></i> Download PDF
        </a>
        @if (canEdit)
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary w-100 mb-3">Edit CV</a>
        }
    </div>
</div>

<hr />

<!-- Comments -->
<h5>Comments (@Model.Comments.Count)</h5>
@if (User.Identity?.IsAuthenticated == true)
{
    <form asp-action="AddComment" method="post" class="mb-4">
        <input type="hidden" name="cvId" value="@Model.Id" />
        <div class="input-group">
            <input type="text" name="message" class="form-control" placeholder="Write a comment..." required />
            <button type="submit" class="btn btn-primary">Send</button>
        </div>
    </form>
}

@if (Model.Comments.Any())
{
    <div class="list-group">
        @foreach (var c in Model.Comments.OrderByDescending(x => x.CreatedAt))
        {
            <div class="list-group-item">
                <strong>@c.User?.FullName</strong> <small class="text-muted">@c.CreatedAt.ToString("dd MMM HH:mm")</small>
                <p class="mb-0">@c.Message</p>
            </div>
        }
    </div>
}
else
{
    <p class="text-muted">No comments yet.</p>
}

<a asp-action="MyApplications" class="btn btn-secondary mt-4">← Back</a>