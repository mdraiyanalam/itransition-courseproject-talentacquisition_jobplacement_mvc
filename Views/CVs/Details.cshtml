@model talentacquisition_jobplacement_mvc.Models.CV
@using talentacquisition_jobplacement_mvc.Helpers
@using System.Security.Claims

@{
    ViewData["Title"] = $"CV - {Model.Position?.Title}";
    var attrValues = ViewBag.AttributeValues as Dictionary<int, string> ?? new Dictionary<int, string>();
    var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    bool isOwner = userId == Model.UserId;
    bool canEdit = isOwner || User.IsInRole("Administrator");
}

<h1>CV for <strong>@Model.Position?.Title</strong></h1>

<div class="row">
    <div class="col-md-8">
        <div class="card mb-4">
            <div class="card-body">
                <h3>@Model.User?.FullName</h3>
                <p><strong>Email:</strong> @Model.User?.Email</p>
                <p><strong>Applied:</strong> @Model.CreatedAt.ToString("dd MMMM yyyy HH:mm")</p>
            </div>
        </div>

        <!-- Like Button -->
        @if (User.IsInRole("Recruiter") || User.IsInRole("Administrator"))
        {
            <div class="mt-3 mb-4">
                <form asp-action="ToggleLike" method="post" style="display: inline;">
                    <input type="hidden" name="cvId" value="@Model.Id" />
                    <button type="submit" class="btn btn-outline-danger btn-lg">
                        <i class="bi bi-heart@(Model.Likes.Any(l => l.UserId == userId) ? "-fill" : "")"></i>
                        <span id="likeCount">@Model.Likes.Count</span>
                    </button>
                </form>
                <small class="text-muted ms-2">Recruiters liked this CV</small>
            </div>
        }

        <!-- Publish Controls -->
        @if (canEdit)
        {
            <div class="mb-4">
                @if (Model.IsPublished)
                {
                    <form asp-action="Unpublish" method="post" style="display:inline;">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-warning">Unpublish</button>
                    </form>
                }
                else
                {
                    <form asp-action="Publish" method="post" style="display:inline;">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-success @(IsCVComplete(Model) ? "" : "disabled")">Publish CV</button>
                    </form>
                }
            </div>
        }

        <!-- Attributes -->
        <h5>Attribute Answers</h5>
        <table class="table table-striped">
            <thead class="table-light">
                <tr>
                    <th>Attribute</th>
                    <th>Value</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var pa in Model.Position?.PositionAttributes.OrderBy(x => x.Order) ?? Enumerable.Empty<PositionAttribute>())
                {
                    var attr = pa.AttributeDefinition;
                    var value = attrValues.GetValueOrDefault(attr.Id, "");
                    bool isEmpty = string.IsNullOrWhiteSpace(value);

                    <tr>
                        <td><strong>@attr.Name</strong> <small>(@attr.Type)</small></td>
                        <td>
                            @if (isEmpty)
                            {
                                <span class="text-danger fw-bold">NOT PROVIDED</span>
                            }
                            else
                            {
                                @value
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <!-- Projects -->
        @if (Model.CandidateProfile?.Projects.Any() == true)
        {
            <h5>Selected Projects</h5>
            @foreach (var p in Model.CandidateProfile.Projects.Take(Model.Position?.MaxProjects ?? 5))
            {
                <div class="border p-3 mb-3 rounded">
                    <h6>@p.Name</h6>
                    <small class="text-muted">@p.StartDate.ToShortDateString() — @(p.EndDate?.ToShortDateString() ?? "Present")</small>
                    <p>@Html.Raw(MarkdownHelper.ToHtml(p.Description))</p>
                    @if (!string.IsNullOrEmpty(p.TechnologyTags))
                    {
                        <p><strong>Technologies:</strong> @p.TechnologyTags</p>
                    }
                </div>
            }
        } }
        }
    </div>

    <!-- Sidebar -->
    <div class="col-md-4">
        <a asp-action="Download" asp-route-id="@Model.Id" class="btn btn-primary w-100 mb-3">
            <i class="bi bi-download"></i> Download PDF
        </a>

        @if (User.IsInRole("Recruiter") || User.IsInRole("Administrator"))
        {
            <a asp-action="ExportCVs" asp-route-id="@Model.Id" class="btn btn-success w-100 mb-3">
                <i class="bi bi-file-earmark-excel"></i> Export to Excel
            </a>
        }

        @if (canEdit)
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary w-100 mb-3">Edit CV</a>
        }
    </div>
</div>

<hr />

<!-- Comments Section -->
<div class="mt-5">
    <h4><i class="bi bi-chat-dots"></i> Comments (@Model.Comments.Count)</h4>
    @if (Model.Comments.Any())
    {
        <div class="comments-container">
            @foreach (var comment in Model.Comments.OrderByDescending(c => c.CreatedAt))
            {
                <div class="card mb-3 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <strong>@comment.User?.FullName</strong>
                                <small class="text-muted ms-2">@comment.CreatedAt.ToString("dd MMM yyyy HH:mm")</small>
                            </div>
                            @if (userId == comment.UserId)
                            {
                                <span class="badge bg-secondary">You</span>
                            }
                        </div>
                        <p class="mt-2 mb-0">@comment.Message</p>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info">No comments yet. Be the first to comment!</div>
    }

    <div class="card mt-4">
        <div class="card-body">
            <form asp-action="AddComment" method="post" id="commentForm">
                <input type="hidden" name="cvId" value="@Model.Id" />
                <div class="input-group">
                    <textarea name="message" class="form-control" rows="2" placeholder="Write a comment..." required></textarea>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-send"></i> Send
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>