@model IEnumerable<talentacquisition_jobplacement_mvc.Models.CV>
@{
    ViewData["Title"] = "All Submitted CVs";
    var searchTerm = ViewBag.SearchTerm as string;
}

<h1>All Submitted CVs</h1>

<form asp-action="Index" method="get" class="mb-4">
    <div class="input-group" style="max-width: 600px;">
        <input type="text" name="search" value="@searchTerm"
               class="form-control" placeholder="Search by candidate name or position title..." />
        <button type="submit" class="btn btn-primary">Search</button>
        @if (!string.IsNullOrEmpty(searchTerm))
        {
            <a asp-action="Index" class="btn btn-secondary">Clear Filter</a>
        }
    </div>
</form>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Candidate</th>
            <th>Position</th>
            <th>Applied Date</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var cv in Model)
        {
            <tr>
                <td>
                    @if (!string.IsNullOrEmpty(cv.User?.ProfilePhotoUrl))
                    {
                        <img src="@cv.User.ProfilePhotoUrl" alt=""
                             class="rounded-circle me-2" style="width:45px;height:45px;object-fit:cover;" />
                    }
                    <strong>@cv.User?.FullName</strong>
                </td>
                <td>@cv.Position?.Title</td>
                <td>@cv.CreatedAt.ToString("dd MMM yyyy HH:mm")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@cv.Id" class="btn btn-sm btn-info">View</a>
                    <a asp-action="Download" asp-route-id="@cv.Id" class="btn btn-sm btn-success">Download PDF</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.Any())
{
    <div class="alert alert-info">No CVs found matching your search.</div>
}