@model IEnumerable<talentacquisition_jobplacement_mvc.Models.CV>

@{
    ViewData["Title"] = "All Submitted CVs";
    var searchTerm = ViewBag.SearchTerm as string ?? "";
}

<h1>All Submitted CVs</h1>

<form asp-action="Index" method="get" class="mb-4">
    <div class="input-group" style="max-width: 650px;">
        <input type="text" name="search" value="@searchTerm"
               class="form-control" placeholder="Search by candidate or position..." />
        <button type="submit" class="btn btn-primary">Search</button>
        @if (!string.IsNullOrEmpty(searchTerm))
        {
            <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
        }
    </div>
</form>

@if (Model.Any())
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Candidate</th>
                <th>Position</th>
                <th>Applied</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var cv in Model)
            {
                <tr>
                    <td>
                        @if (!string.IsNullOrEmpty(cv.User?.ProfilePhotoUrl))
                        {
                            <img src="@cv.User.ProfilePhotoUrl" alt="" class="rounded-circle me-2"
                                 style="width:48px;height:48px;object-fit:cover;" />
                        }
                        <strong>@cv.User?.FullName</strong>
                    </td>
                    <td>@cv.Position?.Title</td>
                    <td>@cv.CreatedAt.ToString("dd MMM yyyy")</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@cv.Id" class="btn btn-sm btn-info">View</a>
                        <a asp-action="Download" asp-route-id="@cv.Id" class="btn btn-sm btn-success">PDF</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-info">No CVs found.</div>
}