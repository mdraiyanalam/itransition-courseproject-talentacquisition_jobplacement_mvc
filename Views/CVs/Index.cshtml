@model IEnumerable<talentacquisition_jobplacement_mvc.Models.CV>
@{
    ViewData["Title"] = "All Applications";
}

<h1>All CV Applications</h1>

<form asp-action="Index" method="get" class="mb-4">
    <div class="row">
        <div class="col-md-6">
            <div class="input-group">
                <input type="text" name="searchString" class="form-control" placeholder="Search candidate or position..." value="@ViewBag.SearchString" />
                <button type="submit" class="btn btn-primary">Search</button>
                @if (!string.IsNullOrEmpty(ViewBag.SearchString))
                {
                    <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
                }
            </div>
        </div>
    </div>
</form>

@if (Model.Any())
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Candidate</th>
                <th>Position</th>
                <th>Applied</th>
                <th>Status</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var cv in Model)
            {
                <tr>
                    <td>@cv.User?.FullName</td>
                    <td>@cv.Position?.Title</td>
                    <td>@cv.CreatedAt.ToString("dd MMM yyyy")</td>
                    <td>
                        @if (cv.IsPublished)
                        {
                            <span class="badge bg-success">Published</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Draft</span>
                        }
                    </td>
                    <td class="text-end">
                        <div class="dropdown">
                            <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">Actions</button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" asp-action="Details" asp-route-id="@cv.Id">View Details</a></li>
                                <li><a class="dropdown-item" asp-action="Download" asp-route-id="@cv.Id">Download PDF</a></li>
                            </ul>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-info">No applications found.</div>
}