@model IEnumerable<talentacquisition_jobplacement_mvc.Models.CV>

@{
    ViewData["Title"] = "All Applications";
}

<h1>All CV Applications</h1>

<form asp-action="Index" method="get" class="mb-4">
    <div class="row">
        <div class="col-md-6">
            <div class="input-group">
                <input type="text" name="searchString" class="form-control"
                       placeholder="Search candidate or position..." value="@ViewBag.SearchString" />
                <button type="submit" class="btn btn-primary">Search</button>
                @if (!string.IsNullOrEmpty(ViewBag.SearchString))
                {
                    <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
                }
            </div>
        </div>
    </div>
</form>

@if (Model.Any())
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Candidate</th>
                <th>Position</th>
                <th>Applied</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var cv in Model)
            {
                <tr>
                    <td>@cv.User?.FullName</td>
                    <td>@cv.Position?.Title</td>
                    <td>@cv.CreatedAt.ToString("dd MMM yyyy")</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@cv.Id" class="btn btn-sm btn-primary">View</a>
                        <a asp-action="Download" asp-route-id="@cv.Id" class="btn btn-sm btn-success">PDF</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-info">No applications found.</div>
}