@model talentacquisition_jobplacement_mvc.Models.CandidateProfile

@{
    ViewData["Title"] = "My Professional Profile";
}

<h1>My Professional Profile</h1>

<form asp-action="Index" method="post">
    <div class="row">
        <div class="col-md-8">
            <div class="mb-3">
                <label class="form-label">Full Name</label>
                <input type="text" class="form-control" value="@Model?.User?.FullName" disabled />
            </div>

            <div class="mb-3">
                <label class="form-label">Professional Summary</label>
                <textarea asp-for="Summary" class="form-control" rows="5"></textarea>
            </div>

            <div class="mb-3">
                <label class="form-label">Experience</label>
                <textarea asp-for="Experience" class="form-control" rows="6" placeholder="Describe your work experience..."></textarea>
            </div>

            <div class="mb-3">
                <label class="form-label">Education</label>
                <textarea asp-for="Education" class="form-control" rows="4"></textarea>
            </div>
        </div>
    </div>

    <button type="submit" class="btn btn-primary">Save Profile</button>
</form>

<hr />

<h3>Apply to Positions</h3>
<p>
    <a asp-controller="Positions" asp-action="Index" class="btn btn-outline-primary">
        Browse Available Positions →
    </a>
</p>