@model talentacquisition_jobplacement_mvc.Models.Project

@{
    ViewData["Title"] = "Edit Project";
}

<h1>Edit Project</h1>

<form asp-action="EditProject">
    <input type="hidden" asp-for="Id" />

    <div class="mb-3">
        <label class="form-label">Project Name</label>
        <input asp-for="Name" class="form-control" required />
    </div>

    <div class="row">
        <div class="col-md-6">
            <label class="form-label">Start Date</label>
            <input type="date" asp-for="StartDate" class="form-control" required />
        </div>
        <div class="col-md-6">
            <label class="form-label">End Date</label>
            <input type="date" asp-for="EndDate" class="form-control" />
        </div>
    </div>

    <div class="mb-3">
        <label class="form-label">Description</label>
        <textarea asp-for="Description" class="form-control" rows="5"></textarea>
    </div>

    <div class="mb-3">
        <label class="form-label">Technologies</label>
        <input asp-for="TechnologyTags" class="form-control" placeholder="C#, ASP.NET, React..." />
    </div>

    <button type="submit" class="btn btn-primary">Save Changes</button>
    <a asp-action="Projects" class="btn btn-secondary">Cancel</a>
</form>