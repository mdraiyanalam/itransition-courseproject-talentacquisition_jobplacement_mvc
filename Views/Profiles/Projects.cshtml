@using talentacquisition_jobplacement_mvc.Helpers
@model IEnumerable<talentacquisition_jobplacement_mvc.Models.Project>

@{
    ViewData["Title"] = "My Projects";
}

<h1>My Projects</h1>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<!-- Add New Project Form -->
<div class="card mb-4">
    <div class="card-body">
        <h5>Add New Project</h5>
        <form asp-action="SaveProject" method="post">
            <div class="row">
                <div class="col-md-5">
                    <input type="text" name="Name" class="form-control" placeholder="Project Name" required />
                </div>
                <div class="col-md-3">
                    <input type="date" name="StartDate" class="form-control" required />
                </div>
                <div class="col-md-3">
                    <input type="date" name="EndDate" class="form-control" />
                </div>
                <div class="col-md-1">
                    <button type="submit" class="btn btn-success">Add</button>
                </div>
            </div>
            <div class="mt-3">
                <textarea name="Description" class="form-control" rows="3" placeholder="Project Description (Markdown supported)"></textarea>
            </div>
            <div class="mt-2">
                <input type="text" name="TechnologyTags" class="form-control" placeholder="Technologies (e.g. C#, ASP.NET, React)" />
            </div>
        </form>
    </div>
</div>

<!-- Projects List -->
@if (Model.Any())
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Project</th>
                <th>Period</th>
                <th>Technologies</th>
                <th>Description</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td><strong>@p.Name</strong></td>
                    <td>@p.StartDate.ToShortDateString() — @(p.EndDate?.ToShortDateString() ?? "Present")</td>
                    <td>@p.TechnologyTags</td>
                    <td>@Html.Raw(MarkdownHelper.ToHtml(p.Description))</td>
                    <td>
                        <a asp-action="EditProject" asp-route-id="@p.Id" class="btn btn-sm btn-warning">Edit</a>
                        <form asp-action="DeleteProject" method="post" style="display:inline;">
                            <input type="hidden" name="id" value="@p.Id" />
                            <button type="submit" class="btn btn-sm btn-danger"
                                    onclick="return confirm('Delete this project?')">
                                Delete
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-info">No projects added yet.</div>
}

<a asp-action="Index" class="btn btn-secondary">← Back to Profile</a>