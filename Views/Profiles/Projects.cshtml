@using talentacquisition_jobplacement_mvc.Helpers
@model IEnumerable<talentacquisition_jobplacement_mvc.Models.Project>
@{
    ViewData["Title"] = "My Projects";
}

<h1>My Projects</h1>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<!-- Improved Add New Project -->
<div class="card mb-4 shadow-sm">
    <div class="card-header bg-light">
        <h5 class="mb-0"><i class="bi bi-plus-circle"></i> Add New Project</h5>
    </div>
    <div class="card-body">
        <form asp-action="SaveProject" method="post">
            <div class="row g-3">
                <div class="col-md-5">
                    <input type="text" name="Name" class="form-control" placeholder="Project Name" required />
                </div>
                <div class="col-md-3">
                    <input type="date" name="StartDate" class="form-control" required />
                </div>
                <div class="col-md-3">
                    <input type="date" name="EndDate" class="form-control" />
                </div>
                <div class="col-md-1">
                    <button type="submit" class="btn btn-success w-100">Add</button>
                </div>
            </div>

            <div class="mt-3">
                <label class="form-label">Technologies / Tags</label>
                <input type="text" name="TechnologyTags" id="techTags"
                       class="form-control" placeholder="C#, ASP.NET, React, SQL..." />
                <small class="text-muted">Type tags separated by commas</small>
            </div>

            <div class="mt-3">
                <label class="form-label">Description (Markdown supported)</label>
                <textarea name="Description" class="form-control" rows="4" placeholder="Describe your project..."></textarea>
            </div>
        </form>
    </div>
</div>

<!-- Projects List -->
@if (Model.Any())
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Project</th>
                <th>Period</th>
                <th>Technologies</th>
                <th>Description</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td><strong>@p.Name</strong></td>
                    <td>@p.StartDate.ToShortDateString() — @(p.EndDate?.ToShortDateString() ?? "Present")</td>
                    <td>
                        @if (!string.IsNullOrEmpty(p.TechnologyTags))
                        {
                            foreach (var tag in p.TechnologyTags.Split(',').Select(t => t.Trim()).Where(t => !string.IsNullOrEmpty(t)))
                            {
                                <span class="badge bg-primary me-1">@tag</span>
                            }
                        }
                    </td>
                    <td>@Html.Raw(MarkdownHelper.ToHtml(p.Description))</td>
                    <td>
                        <a asp-action="EditProject" asp-route-id="@p.Id" class="btn btn-sm btn-warning">Edit</a>
                        <form asp-action="DeleteProject" method="post" style="display:inline;">
                            <input type="hidden" name="id" value="@p.Id" />
                            <button type="submit" class="btn btn-sm btn-danger"
                                    onclick="return confirm('Delete this project?')">
                                Delete
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-info">No projects added yet.</div>
}

<a asp-action="Index" class="btn btn-secondary">← Back to Profile</a>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const tagInput = document.getElementById('techTags');
            tagInput.addEventListener('keypress', function (e) {
                if (e.key === ',' || e.key === 'Enter') {
                    e.preventDefault();
                    let value = this.value.trim();
                    if (value) this.value = '';
                }
            });
            tagInput.addEventListener('blur', function () {
                this.value = this.value.trim();
            });
        });
    </script>
}