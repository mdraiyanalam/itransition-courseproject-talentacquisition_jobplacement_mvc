@page
@model RegisterConfirmationModel
@{
    ViewData["Title"] = "Registration Successful";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-7 col-lg-5">
        <div class="card shadow">
            <div class="card-body text-center p-5">
                <!-- Success Icon -->
                <div class="mb-4">
                    <i class="bi bi-check-circle-fill text-success" style="font-size: 5rem;"></i>
                </div>

                <h2 class="mb-3 text-success">Registration Successful!</h2>
                <p class="lead mb-4">Thank you for joining Talent Acquisition</p>

                <div class="alert alert-success text-start">
                    <h5>Please check your email</h5>
                    <p>We have sent a confirmation link to <strong>@Model.Email</strong>.</p>
                    <p class="mb-0">Please check your spam/junk folder if you don't see it.</p>
                </div>

                <div class="mt-4">
                    <a asp-page="/Account/Login" class="btn btn-outline-primary me-2">
                        <i class="bi bi-box-arrow-in-right"></i> Go to Login
                    </a>
                    <a asp-page="./ResendEmailConfirmation" class="btn btn-link text-primary">
                        Resend Email
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>